# Kalinga — optional environment configuration.
# Copy to `.env` (gitignored) and fill in only what you need. NOTHING here is
# required for the default setup: the creative model runs on your `claude` CLI
# login and generation on your `higgsfield` CLI login.

# --- LLM backend (creative: script, direction, judges) ---
# Default backend is the `claude` CLI on your subscription ($0 marginal).
# Force the API instead (needs a key) with these:
# KALINGA_BACKEND=api
# ANTHROPIC_API_KEY=sk-ant-...

# Per-role model overrides (defaults are sensible). KALINGA_MODEL pins all roles.
# KALINGA_MODEL=
# KALINGA_MODEL_RESEARCH=
# KALINGA_MODEL_SCRIPT=
# KALINGA_MODEL_DIRECTION=
# KALINGA_MODEL_JUDGE=

# --- channel selection (only needed when you have more than one channel) ---
# KALINGA_CHANNEL=daily-science

# --- text-to-speech ---
# Default is free edge-tts (karaoke timings). Optional ElevenLabs voice/music:
# TTS_ENGINE=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# HF_VOICE=                 # override the Higgsfield/Inworld voice

# --- generation provider / renderers (advanced) ---
# KALINGA_PROVIDER=higgsfield
# KALINGA_KENBURNS=ffmpeg   # ffmpeg | remotion (needs plugins/remotion installed)
# FFMPEG_FULL=              # path to a libass-enabled ffmpeg for burned captions
